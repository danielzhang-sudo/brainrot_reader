# Backend Configuration
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8090
CORS_ORIGINS=*
STORAGE_DIR=/app/epubs

# Frontend Configuration
FRONTEND_HOST=0.0.0.0
FRONTEND_PORT=3000

# Optional: override the auto-detected API URL.
# If left empty, the frontend defaults to http://<browser-host>:8090
# which works when both services run on the same machine/network.
NEXT_PUBLIC_API_URL=